# Runtime mode: 'kiosk' (stand TV, reads serial telemetry) or 'server' (remote, ingests from kiosk).
APP_MODE=kiosk

# Kiosk-mode telemetry source: a serial device path (e.g. /dev/ttyUSB0) or 'simulated'.
KIOSK_TELEMETRY_SOURCE=simulated

# Kiosk SQLite database file path. Default: ./data/kiosk.db
KIOSK_DB_PATH=./data/kiosk.db

# Race start timestamp in ISO-8601-with-offset format (e.g. 2026-05-23T16:00:00+02:00).
# Default: 2026-05-23T16:00:00+02:00 (16:00 CEST on race day).
# RACE_START_AT=2026-05-23T16:00:00+02:00
